# Generated by `npm run admin:setup` (paste the values it prints).
ADMIN_PASSWORD_HASH=
ADMIN_TOTP_SECRET=
SESSION_SECRET=

# Fine-grained PAT scoped to THIS repo only, with contents:write.
# Create at https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=
GITHUB_REPO=adriandomc/portfolio
GITHUB_DEFAULT_BRANCH=main

# Optional: customise the commit author shown in Git history.
# GIT_AUTHOR_NAME=Portfolio Admin
# GIT_AUTHOR_EMAIL=admin@adriandomc.com

# Set to 1 to write changes to the local filesystem instead of GitHub
# (useful for testing locally without a token).
# ADMIN_DRY_RUN=1
