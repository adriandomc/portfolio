---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
import Card from "../components/Card.astro";
const title = "Home";

const techStack = {
  Frontend: ["React", "TypeScript", "Astro", "HTML/CSS", "SCSS"],
  Backend: ["Node.js", "PHP", "Ruby", "Express", "REST APIs"],
  Tools: ["Git", "Docker", "Coolify", "Figma"],
};
---

<BaseLayout title={title} description="Portfolio of Adrián Domínguez — Software Developer from Mexico specializing in React, TypeScript, PHP and Node.js.">
  <Menu activeItem="Home" />
  <main id="main-content">
    <h1 style="margin-bottom:1rem">
      <span class="main-name">ADRIÁN DOMÍNGUEZ CASASOLA</span>
      <br />
      <span class="main-job-position">SOFTWARE DEVELOPER</span>
    </h1>
    <div class="container">
      <img src="/images/adrian.jpeg" alt="Profile Picture" width="240" height="240" />
      <div class="presentation">
        <h2>Hello!</h2>
        <p>
          My name is Adrián, I am a software developer from Mexico. My current
          focus is on frontend web solutions, however I have experience working
          through the whole web stack, from the design to the deployment of
          fully fledged products.
        </p>
      </div>
    </div>
  </main>
  <section class="tech-stack">
    <h2>Tech Stack</h2>
    <div class="stack-grid">
      {
        Object.entries(techStack).map(([category, tools]) => (
          <Card title={category}>
            <div class="stack-badges">
              {tools.map((tool) => (
                <Badge title={tool} />
              ))}
            </div>
          </Card>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-top: 2rem;
    margin-bottom: 2rem;
  }

  .container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    background-color: $color-primary;
    border: 1px solid $color-accent-1;
    border-radius: 5px;
    padding: 1rem;

    img {
      flex: 0 0 15rem;
      width: 15rem;
      height: 15rem;
      border: 1px solid $color-accent-1;
      border-radius: 50%;
      object-fit: cover;
    }

    .presentation {
      display: flex;
      flex-direction: column;
      flex: 1 1 20rem;
    }
  }

  h1 {
    text-align: center;
  }

  .main-name {
    color: $color-accent-1;
  }

  .main-job-position {
    color: $color-accent-2;
  }

  .stack-grid {
  margin-top: 0.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;

    @include respond-to("tablet") {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .stack-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
