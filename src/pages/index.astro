---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
const title = "Home";

const badges: string[] = ["React", "Typescript", "PHP", "Node.js"];
---

<BaseLayout title={title} description="Portfolio of Adrián Domínguez — Software Developer from Mexico specializing in React, TypeScript, PHP and Node.js.">
  <Menu activeItem="Home" />
  <main id="main-content">
    <h1>
      <span class="main-name">ADRIÁN DOMÍNGUEZ</span>
      <br />
      <span class="main-job-position">SOFTWARE DEVELOPER</span>
    </h1>
    <div class="container">
      <img src="/images/adrian.jpeg" alt="Profile Picture" width="240" height="240" />
      <div class="presentation">
        <h2>Hello!</h2>
        <p>
          My name is Adrián, I am a software developer from Mexico. My current
          focus is on frontend web solutions, however I have experience working
          through the whole web stack, from the design to the deployment of
          fully fledged products.
        </p>
        <div class="badge-container">
          {badges.map((badge) => <Badge title={badge} />)}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin-top: 2rem;
  }

  .container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
    background-color: $color-primary;
    border: 1px solid $color-accent-1;
    border-radius: 5px;
    padding: 1rem;

    img {
      flex: 0 0 15rem;
      width: 15rem;
      height: 15rem;
      border: 1px solid $color-accent-1;
      border-radius: 50%;
      object-fit: cover;
    }

    .presentation {
      display: flex;
      flex-direction: column;
      flex: 1 1 20rem;
    }
  }

  h1 {
    text-align: center;
  }

  .main-name {
    color: $color-accent-1;
  }

  .main-job-position {
    color: $color-accent-2;
  }

  .badge-container {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }
</style>
