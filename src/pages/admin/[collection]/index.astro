---
export const prerender = false;

import AdminLayout from "../../../layouts/AdminLayout.astro";
import ContentTable from "../../../components/admin/ContentTable.svelte";
import { COLLECTIONS, listPosts, type Collection } from "../../../lib/admin/posts";

const { collection } = Astro.params;
if (!collection || !COLLECTIONS.includes(collection as Collection)) {
  return Astro.redirect("/admin");
}
const col = collection as Collection;

let posts: Awaited<ReturnType<typeof listPosts>> = [];
let loadError: string | null = null;
try {
  posts = await listPosts(col);
} catch (err) {
  loadError = err instanceof Error ? err.message : "Failed to load posts.";
}

const labels: Record<Collection, string> = {
  blog: "Blog posts",
  projects: "Projects",
};
---

<AdminLayout title={labels[col]}>
  {loadError ? (
    <p class="error">{loadError}</p>
  ) : (
    <ContentTable client:load collection={col} label={labels[col]} posts={posts} />
  )}
</AdminLayout>

<style lang="scss">
  .error {
    background-color: $color-error;
    color: $color-white;
    border-radius: 5px;
    padding: 0.75rem 1rem;
    font-size: $fs-sm;
  }
</style>
