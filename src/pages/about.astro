---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
import Card from "../components/Card.astro";
import JobCard from "../components/JobCard.astro";

const title = "About";

const techStack = {
  Frontend: ["React", "TypeScript", "Astro", "HTML/CSS", "SCSS"],
  Backend: ["Node.js", "PHP", "Ruby", "Express", "REST APIs"],
  Tools: ["Git", "Docker", "Coolify", "Figma"],
};

const jobsExperience = [
  {
    header: "Software Solutions Developer @ BBVA",
    period: "August 2025 — Present",
    stack: [
      "Javascript", "CELLS", "SCSS", "HTML"
    ],
    activities: [
      "",
      "",
      ""
    ]
  },
  {
    header: "Full-stack Developer @ WAAK Technologies",
    period: "October 2024 — August 2025",
    stack: [
      "PHP", "jQuery", "Node.js"
    ],
    activities: [
      "Developed web platforms for clients with large-scale operations in the construction, transportation and logistics industry, with mobile-app integration and multi-tenant database systems.",
      "Designed data visualization tools, such as unit tracking maps, dynamic reports with position markers and a real-time timetable to monitor units' routines.",
      ""
    ]
  }
];
---

<BaseLayout title={title} description="About Adrián Domínguez — Software Developer from Mexico with a focus on frontend web solutions.">
  <Menu activeItem="About" />
  <main id="main-content">
    <h1>About Me</h1>

    <section class="bio">
      <Card>
        <p>
          I'm Adrián Domínguez, a software developer based in Mexico. I specialize
          in building modern web applications with a focus on clean code,
          performance, and user experience.
        </p>
        <p>
          My journey in software development has taken me across the full web
          stack, from crafting interfaces with React and TypeScript
          to building backend services with Node.js and PHP. I enjoy the
          process of creating new ideas, from their conception to the deployment phase.
        </p>
        <p>
          In my free time, I like to compose music (check out <a href="https://cosmicdinodog.xyz" target="_blank">The Cosmic Dinodog</a>), read science fiction/fantasy books, learn japanese
          and have amazing adventures with my fiancee!
        </p>
      </Card>
    </section>

    <section class="tech-stack">
      <h2>Tech Stack</h2>
      <div class="stack-grid">
        {
          Object.entries(techStack).map(([category, tools]) => (
            <Card title={category}>
              <div class="stack-badges">
                {tools.map((tool) => (
                  <Badge title={tool} />
                ))}
              </div>
            </Card>
          ))
        }
      </div>
    </section>

    <section class="experience">
      <h2>Experience</h2>
      <div class="timeline">
        {
        jobsExperience.map((job) => (
          <JobCard data={job} />
        ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    margin-top: 2rem;
  }

  h1 {
    margin-bottom: 1.5rem;
  }

  h2 {
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  section {
    margin-bottom: 1rem;
  }

  .bio p {
    margin-bottom: 0.75rem;

    &:last-child {
      margin-bottom: 0;
    }
  }

  .stack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;

    @include respond-to("tablet") {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .stack-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
