---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
import Card from "../components/Card.astro";
import JobCard from "../components/JobCard.astro";

const title = "About";

const jobsExperience = [
  {
    header: "Software Solutions Developer @ BBVA",
    period: "August 2025 — Present",
    stack: [
      "Javascript", "CELLS", "SCSS", "HTML"
    ],
    activities: [
      "",
      "",
      ""
    ]
  },
  {
    header: "Full-stack Developer @ WAAK Technologies",
    period: "October 2024 — August 2025",
    stack: [
      "PHP", "jQuery", "Node.js"
    ],
    activities: [
      "Developed web platforms for clients with large-scale operations in the construction, transportation and logistics industry, with mobile-app integration and multi-tenant database systems.",
      "Designed data visualization tools, such as unit tracking maps, dynamic reports with position markers and a real-time timetable to monitor units' routines.",
      ""
    ]
  },
  {
    header: "Front-end Developer (Freelancer)",
    period: "September 2021 - present",
    stack: [
      "Typescript", "PHP", "Astro", "Ruby on Rails"
    ],
    activities: [
      "",
      "",
      ""
    ]
  }
];
---

<BaseLayout title={title} description="About Adrián Domínguez — Software Developer from Mexico with a focus on frontend web solutions.">
  <Menu activeItem="About" />
  <main id="main-content">
    <h1>About Me</h1>

    <section class="bio">
      <Card>
        <p>
          I'm Adrián Domínguez, a software developer based in Mexico. I specialize
          in building modern web applications with a focus on clean code,
          performance, and user experience.
        </p>
        <p>
          My journey in software development has taken me across the full web
          stack, from crafting interfaces with React and TypeScript
          to building backend services with Node.js and PHP. I enjoy the
          process of creating new ideas, from their conception to the deployment phase.
        </p>
        <p>
          Aside of my programming and technology passion, I love to compose music
          (<a href="https://cosmicdinodog.xyz" target="_blank">The Cosmic Dinodog</a>),
          learning to play different musical instruments and exploring different artistic
          endeavours along with my fiancee.
        </p>
        <p>
          If you want to know more about my interests and side projects, visit
          <a href="https://adriandomc.com" target="_blank">my personal website</a> (it is
          currently in Spanish).
        </p>
      </Card>
    </section>
    <section class="experience">
      <h2>Job Experience</h2>
      <div class="timeline">
        {
        jobsExperience.map((job) => (
          <JobCard data={job} />
        ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    margin-top: 2rem;
  }

  h1 {
    margin-bottom: 1.5rem;
  }

  h2 {
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  section {
    margin-bottom: 1rem;
  }

  .bio p {
    margin-bottom: 0.75rem;

    &:last-child {
      margin-bottom: 0;
    }
  }

  .stack-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;

    @include respond-to("tablet") {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .stack-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
