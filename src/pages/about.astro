---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Card from "../components/Card.astro";
import JobCard from "../components/JobCard.astro";

const title = "About";

const jobsExperience = [
  {
    header: "Co-founder @ VoltAlfa Corporation ",
    period: "February 2026 — Present",
    stack: [
      "Typescript", "Svelte", "DevOps", "Team Management"
    ],
    activities: [
      "Led a small engineering team to design, build and ship a local-first point of sale application for desktop and mobile, taking ownership from architecture to distribution",
      "Built a dev-tools platform in SvelteKit and Typescript with access to self-hosted tools, such as Wiki.js, AFFiNE and Excalidraw, behind a unified sign-on usign Authentik",
      "Designed the brand identity of the company and built its marketing website, as well as manage email and social media for commercial purposes"
    ]
  },
  {
    header: "Software Solutions Developer @ BBVA",
    period: "August 2025 — Present",
    stack: [
      "Javascript", "CELLS", "SCSS", "HTML"
    ],
    activities: [
      "Developed scalable frontend components and user interfaces for corporate banking applications using CELLS (LitElement) and WebComponents",
      "Collaborated on the product design and roadmap for a digital leasing platform, implementing secure coding practices and future-proof data management",
      "Led QA testing sessions by generating and executing end-to-end manual and automated test cases, ensuring high reliability across the critical user flow"
    ]
  },
  {
    header: "Full-stack Developer @ WAAK Technologies",
    period: "October 2024 — August 2025",
    stack: [
      "PHP", "jQuery", "Node.js", "MySQL"
    ],
    activities: [
      "Developed web platforms for clients with large-scale operations in the construction, transportation and logistics industry, with mobile-app integration and multi-tenant database systems",
      "Integrated third-party services like the Wialon Logistics API to engineer data visualization tools, dynamic reporting, and real-time unit tracking maps",
      "Partnered with stakeholders to gather software requirements, translate them into technical documentation, and deliver personnel training"
    ]
  },
  {
    header: "Front-end Developer (Freelancer)",
    period: "September 2021 - present",
    stack: [
      "Typescript", "PHP", "Astro", "Ruby on Rails", "PostgreSQL"
    ],
    activities: [
      "Developed a POS web platform for retail using Ruby on Rails and PostgreSQL, featuring real-time interactions, custom QR/barcode editors, and draggable window interfaces",
      "Implemented tailored frontend solutions using Bootstrap, Astro, React, Bulma CSS, and Node.js, optimizing website performance and user experience across diverse projects",
      "Managed project deployment and maintenance on Netlify, Coolify and GitHub Pages, ensuring 99.9% uptime and implementing robust version control using Git"
    ]
  }
];
---

<BaseLayout title={title} description="About Adrián Domínguez — Software Developer from Mexico with a focus on frontend web solutions.">
  <Menu activeItem="About" />
  <main id="main-content">
    <h1>About Me</h1>
    <section class="bio">
      <Card>
        <p>
          I'm Adrián Domínguez, a software developer based in Mexico. I specialize
          in building modern web applications with a focus on clean code,
          performance, and user experience.
        </p>
        <p>
          My journey in software development has taken me across the full web
          stack, from crafting interfaces with React and TypeScript
          to building backend services with Node.js and PHP. I enjoy the
          process of creating new ideas, from their conception to the deployment phase.
        </p>
        <p>
          Aside of my programming and technology passion, I love to compose music
          (<a href="https://cosmicdinodog.xyz" target="_blank">The Cosmic Dinodog</a>),
          learning to play different musical instruments and exploring different artistic
          endeavours along with my fiancee.
        </p>
        <p>
          If you want to know more about my interests and side projects, visit
          <a href="https://adriandomc.com" target="_blank">my personal website</a> (it is
          currently in Spanish).
        </p>
      </Card>
    </section>
    <section class="experience">
      <h2>Job Experience</h2>
      <div class="timeline">
        {
        jobsExperience.map((job) => (
          <JobCard data={job} />
        ))
        }
      </div>
    </section>
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    margin-top: 2rem;
  }

  h1 {
    margin-bottom: 1.5rem;
  }

  h2 {
    margin-bottom: 1rem;
    margin-top: 2rem;
  }

  section {
    margin-bottom: 1rem;
  }

  .bio p {
    margin-bottom: 0.75rem;

    &:last-child {
      margin-bottom: 0;
    }
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
