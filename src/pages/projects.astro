---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ImageViewer from "../components/ImageViewer.astro";

const title = "Projects";

const projects = [
  {
    title: "Point of Sale Web Platform",
    description:
      "A web platform developed for a shoe store, with a realtime window-based interface, complete inventory control and custom tools like barcode, QR and tickets generator.",
    images: [
      {
        src: "/images/projects/zapa-pos/1.png",
        alt: "Admin dashboard with products, sales and orders metrics",
      },
      {
        src: "/images/projects/zapa-pos/2.png",
        alt: "QR code tag creator with custom position, text size multiple template layouts",
      },
      {
        src: "/images/projects/zapa-pos/3.png",
        alt: "Point of sale for cash register",
      },
      {
        src: "/images/projects/zapa-pos/4.png",
        alt: "Multi-window interface for fast access to tools",
      }
    ],
    tags: ["Ruby on Rails", "Vue.js", "SCSS", "PostgreSQL"],
    href: "",
  },
  {
    title: "Dinotext",
    description:
      "Dinotext is a markup language, inspired by Markdown, which is the engine powering my main website (adriandomc.com). It is currently in a very early stage, but I have plans to make it a more formal markup language with real-world applications.",
    tags: ["PHP"],
    href: "",
  },
];
---

<BaseLayout title={title} description="Projects by Adrián Domínguez — a showcase of web development work.">
  <Menu activeItem="Projects" />
  <main id="main-content">
    <h1>Projects</h1>
    <span class="info-text">(Click on images for full-size view)</span>
    <div class="projects-grid">
      {
        projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            images={project.images}
            href={project.href}
          />
        ))
      }
    </div>
  </main>
  <ImageViewer />
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    margin-top: 2rem;
  }

  .info-text {
    margin-bottom: 1.5rem;
    color: $color-accent-1;
    font-size: 0.85rem;
    font-style: italic;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @include respond-to("tablet") {
      grid-template-columns: repeat(2, 1fr);
    }

    @include respond-to("desktop") {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
