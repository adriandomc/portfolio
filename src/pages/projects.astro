---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ImageViewer from "../components/ImageViewer.astro";

import projects from "../data/projects.json";

const title = "Projects";
---

<BaseLayout title={title} description="Projects by Adrián Domínguez — a showcase of web development work.">
  <Menu activeItem="Projects" />
  <main id="main-content">
    <h1>Projects</h1>
    <span class="info-text">(Click on images for full-size view)</span>
    <div class="projects-grid">
      {
        projects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            images={project.images}
            href={project.href}
          />
        ))
      }
    </div>
  </main>
  <ImageViewer />
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    margin-top: 2rem;
  }

  .info-text {
    margin-bottom: 1.5rem;
    color: $color-accent-1;
    font-size: 0.85rem;
    font-style: italic;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @include respond-to("tablet") {
      grid-template-columns: repeat(2, 1fr);
    }

    @include respond-to("desktop") {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
