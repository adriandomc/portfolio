---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
import { getCollection } from "astro:content";

const title = "Blog";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title={title} description="Blog posts by Adrián Domínguez about web development, TypeScript, and software engineering.">
  <Menu activeItem="Blog" />
  <main id="main-content">
    <h1>Blog</h1>
    {
      posts.length === 0 ? (
        <p class="empty-state">There are no posts here!</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => {
            const formattedDate = post.data.date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });

            return (
              <li>
                <a href={`/blog/${post.id}`} class="post-card">
                  <div class="post-card-content">
                    <h2>{post.data.title}</h2>
                    <time datetime={post.data.date.toISOString()}>
                      {formattedDate}
                    </time>
                    <p>{post.data.description}</p>
                    {post.data.tags.length > 0 && (
                      <div class="post-tags">
                        {post.data.tags.map((tag) => (
                          <Badge title={tag} />
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )
    }
  </main>
</BaseLayout>

<style lang="scss">
  main {
    display: flex;
    flex-direction: column;
    margin-top: 2rem;
  }

  h1 {
    margin-bottom: 1.5rem;
  }

  .empty-state {
    text-align: center;
    color: $color-accent-1;
    padding: 3rem 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .post-card {
    display: block;
    background-color: $color-primary;
    border: 1px solid $color-accent-1;
    border-radius: 5px;
    padding: 1.25rem;
    text-decoration: none;
    color: $color-text;
    transition: transform 0.2s ease, box-shadow 0.2s ease;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba($color-accent-1, 0.2);
    }
  }

  .post-card-content {
    h2 {
      font-size: 1.25rem;
      margin-bottom: 0.25rem;
    }

    time {
      font-size: 0.8rem;
      color: $color-accent-1;
    }

    p {
      margin-top: 0.5rem;
      font-size: 0.9rem;
      line-height: 1.5;
      color: $color-accent-1;
    }
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }
</style>
