---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="card">
  {title && <h3 class="card-title">{title}</h3>}
  <div class="card-content">
    <slot />
  </div>
</div>

<style lang="scss">
  .card {
    background-color: $color-primary;
    border: 1px solid $color-accent-1;
    border-radius: 5px;
    padding: 1.25rem;
  }

  .card-title {
    margin-bottom: 0.75rem;
    font-size: $fs-lg;
  }

  .card-content {
    line-height: 1.6;
  }
</style>
