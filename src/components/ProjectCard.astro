---
import Badge from "./Badge.astro";
import ImageSlideshow from "./ImageSlideshow.astro";

interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  title: string;
  description: string;
  images?: ImageItem[];
  href?: string;
  tags?: string[];
}

const { title, description, images = [], href, tags = [] } = Astro.props;
---

<article class="project-card">
  {
    images.length > 1 ? (
      <div
        class="project-image project-image-clickable"
        data-image-viewer={JSON.stringify(images)}
        data-image-viewer-index="0"
      >
        <ImageSlideshow images={images} />
      </div>
    ) : images.length === 1 ? (
      <div
        class="project-image project-image-clickable"
        data-image-viewer={JSON.stringify(images)}
        data-image-viewer-index="0"
      >
        <img src={images[0].src} alt={images[0].alt} loading="lazy" />
      </div>
    ) : (
      <div class="project-image project-image-placeholder">
        <span>{title.charAt(0)}</span>
      </div>
    )
  }
  <div class="project-body">
    <h3 class="project-title">
      {href ? <a href={href} target="_blank" rel="noopener noreferrer">{title}</a> : title}
    </h3>
    <p class="project-description">{description}</p>
    {
      tags.length > 0 && (
        <div class="project-tags">
          {tags.map((tag) => (
            <Badge title={tag} />
          ))}
        </div>
      )
    }
  </div>
</article>

<style lang="scss">
  .project-card {
    background-color: $color-primary;
    border: 1px solid $color-accent-1;
    border-radius: 5px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;

    &:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba($color-accent-1, 0.2);
    }
  }

  .project-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid $color-accent-1;

    &.project-image-clickable {
      cursor: pointer;
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: fill;
    }
  }

  .project-image-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: $color-secondary;

    span {
      font-size: 3rem;
      font-weight: 800;
      color: $color-accent-1;
      opacity: 0.5;
    }
  }

  .project-body {
    padding: 1rem;
  }

  .project-title {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;

    a {
      color: $color-text;
      text-decoration: underline;
      text-decoration-thickness: 2px;
      text-underline-offset: 2px;

      &:hover {
        color: color.adjust($color-text, $lightness: 20%);
      }
    }
  }

  .project-description {
    font-size: 0.85rem;
    color: color.adjust($color-accent-1, $lightness: -10%);
    line-height: 1.5;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }
</style>
