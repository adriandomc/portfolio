---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images: ImageItem[];
  navigation?: boolean;
  pagination?: boolean;
  autoplay?: boolean;
  autoplayDelay?: number;
  aspectRatio?: string;
  objectFit?: "fill" | "contain" | "cover";
}

const {
  images,
  navigation = false,
  pagination = false,
  autoplay = true,
  autoplayDelay = 2500,
  aspectRatio = "auto",
  objectFit = "fill",
} = Astro.props;
---

<swiper-container
  effect="fade"
  fade-effect-cross-fade="true"
  autoplay={autoplay ? "true" : undefined}
  autoplay-delay={autoplay ? autoplayDelay : undefined}
  autoplay-disable-on-interaction={autoplay ? "false" : undefined}
  loop="true"
  speed="800"
  navigation={navigation}
  pagination={pagination}
  style={`--slideshow-aspect-ratio: ${aspectRatio}; --slideshow-object-fit: ${objectFit};`}
>
  {images.map((image) => (
    <swiper-slide>
      <img src={image.src} alt={image.alt} loading="lazy" />
    </swiper-slide>
  ))}
</swiper-container>

<script>
  import { register } from "swiper/element/bundle";
  register();
</script>

<style lang="scss">
  swiper-container {
    width: 100%;
    height: 100%;
    aspect-ratio: var(--slideshow-aspect-ratio);
    --swiper-navigation-color: #{$color-white};
    --swiper-pagination-color: #{$color-white};
    --swiper-pagination-bullet-inactive-color: rgba(255, 255, 255, 0.5);
    --swiper-pagination-bullet-inactive-opacity: 1;
    --swiper-navigation-size: 1.5rem;
  }

  swiper-slide {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  swiper-slide img {
    width: 100%;
    height: 100%;
    object-fit: var(--slideshow-object-fit);
  }

  swiper-container::part(button-prev),
  swiper-container::part(button-next) {
    width: 2rem;
    height: 2rem;
    padding: 0.5rem;
    transform: translateY(-50%);
    margin: 0 0.3rem;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(8px);
    transition: background 0.15s ease, opacity 0.15s ease;
    opacity: 0.4;
  }

  swiper-container:hover::part(button-prev),
  swiper-container:hover::part(button-next) {
    opacity: 1;
  }

  swiper-container::part(pagination) {
    bottom: 0.75rem;
  }
</style>