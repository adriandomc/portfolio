---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images: ImageItem[];
}

const { images } = Astro.props;
---

<swiper-container
  effect="fade"
  fade-effect-cross-fade="true"
  autoplay-delay="2500"
  autoplay-disable-on-interaction="false"
  loop="true"
  speed="800"
>
  {images.map((image) => (
    <swiper-slide>
      <img src={image.src} alt={image.alt} loading="lazy" />
    </swiper-slide>
  ))}
</swiper-container>

<script>
  import { register } from "swiper/element/bundle";
  register();
</script>

<style lang="scss">
  swiper-container {
    width: 100%;
    height: 100%;
  }

  swiper-slide {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  swiper-slide img {
    width: 100%;
    height: 100%;
    object-fit: fill;
  }
</style>