---
import BaseLayout from "./BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
import ImageViewer from "../components/ImageViewer.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title} description={description}>
  <Menu activeItem="Blog" />
  <main id="main-content">
    <article class="blog-post">
      <header class="post-header">
        <a href="/blog" class="back-link">&larr; Back to blog</a>
        <h1>{title}</h1>
        <div class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {
            tags.length > 0 && (
              <div class="post-tags">
                {tags.map((tag) => (
                  <Badge title={tag} />
                ))}
              </div>
            )
          }
        </div>
      </header>
      <div class="post-content">
        <slot />
      </div>
    </article>
  </main>
  <ImageViewer />
</BaseLayout>

<style lang="scss">
  .blog-post {
    margin-top: 2rem;
    max-width: 50rem;
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    color: $color-accent-1;
    text-decoration: none;
    font-size: $fs-xl;
    margin-bottom: 1rem;
    transition: color 0.2s ease;

    &:hover {
      color: $color-accent-2;
    }
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid $color-accent-1;

    h1 {
      margin-bottom: 0.75rem;
    }
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;

    time {
      color: $color-accent-1;
    }
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-content {
    line-height: 1.8;

    :global(h2) {
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    :global(h3) {
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    :global(p) {
      margin-bottom: 1rem;
    }

    :global(ul),
    :global(ol) {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }

    :global(li) {
      margin-bottom: 0.25rem;
    }

    :global(code) {
      background-color: $color-primary;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      font-size: 0.9em;
    }

    :global(pre) {
      background-color: $color-accent-1;
      border: 1px solid $color-accent-1;
      position: relative;
      color: $color-white;
      padding: 2.65rem 1rem 1rem;
      border-radius: 5px;
      overflow-x: auto;
      margin-bottom: 1.5rem;

      :global(code) {
        background: none;
        display: block;
        padding: 0;
        font-size: $fs-sm;
      }
    }

    :global(pre[data-language]::before) {
      background-color: $color-primary;
      border: 1px solid rgba($color-white, 0.25);
      border-radius: 4px;
      color: $color-text;
      content: attr(data-language);
      font-size: $fs-xs;
      font-weight: 800;
      left: 0.75rem;
      letter-spacing: 0.08em;
      line-height: 1;
      padding: 0.35rem 0.5rem;
      position: absolute;
      text-transform: uppercase;
      top: 0.65rem;
      z-index: 1;
    }

    :global(blockquote) {
      border-left: 3px solid $color-accent-2;
      margin: 1.5rem 0;
      padding: 0.5rem 1rem;
      background-color: $color-primary;
      border-radius: 0 5px 5px 0;

      :global(p) {
        margin: 0;
      }
    }

    :global(img) {
      border-radius: 5px;
      border: 1px solid $color-accent-1;
    }
  }
</style>
