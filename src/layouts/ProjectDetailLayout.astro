---
import BaseLayout from "./BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Badge from "../components/Badge.astro";
import ImageViewer from "../components/ImageViewer.astro";

interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
}

const { title, description, tags = [], href } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Menu activeItem="Projects" />
  <main id="main-content">
    <article class="project-detail">
      <header class="detail-header">
        <a href="/projects" class="back-link">&larr; Back to projects</a>
        <h1>{title}</h1>
        <p class="detail-description">{description}</p>
        {
          (tags.length > 0 || href) && (
            <div class="detail-meta">
              {tags.length > 0 && (
                <div class="detail-tags">
                  {tags.map((tag) => (
                    <Badge title={tag} />
                  ))}
                </div>
              )}
              {href && (
                <a
                  href={href}
                  class="visit-site"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Visit site &#8599;
                </a>
              )}
            </div>
          )
        }
      </header>
      <div class="detail-content">
        <slot />
      </div>
    </article>
  </main>
  <ImageViewer />
</BaseLayout>

<style lang="scss">
  .project-detail {
    margin-top: 2rem;
    max-width: 50rem;
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    color: $color-accent-1;
    text-decoration: none;
    font-size: $fs-xl;
    margin-bottom: 1rem;
    transition: color 0.2s ease;

    &:hover {
      color: $color-accent-2;
    }
  }

  .detail-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid $color-accent-1;

    h1 {
      margin-bottom: 0.75rem;
    }
  }

  .detail-description {
    color: color.adjust($color-accent-1, $lightness: -10%);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .detail-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .visit-site {
    color: $color-accent-1;
    text-decoration: none;
    font-size: $fs-md;
    border: 1px solid $color-accent-1;
    border-radius: 5px;
    padding: 0.35rem 0.75rem;
    transition: color 0.2s ease, border-color 0.2s ease;

    &:hover {
      color: $color-accent-2;
      border-color: $color-accent-2;
    }
  }

  .detail-content {
    line-height: 1.8;

    :global(h2) {
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }

    :global(h3) {
      margin-top: 1.5rem;
      margin-bottom: 0.5rem;
    }

    :global(p) {
      margin-bottom: 1rem;
    }

    :global(ul),
    :global(ol) {
      margin-bottom: 1rem;
      padding-left: 1.5rem;
    }

    :global(li) {
      margin-bottom: 0.25rem;
    }

    :global(code) {
      background-color: $color-primary;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      font-size: 0.9em;
    }

    :global(pre) {
      background-color: $color-accent-1;
      color: $color-white;
      padding: 1rem;
      border-radius: 5px;
      overflow-x: auto;
      margin-bottom: 1.5rem;

      :global(code) {
        background: none;
        padding: 0;
        font-size: $fs-sm;
      }
    }

    :global(blockquote) {
      border-left: 3px solid $color-accent-2;
      margin: 1.5rem 0;
      padding: 0.5rem 1rem;
      background-color: $color-primary;
      border-radius: 0 5px 5px 0;

      :global(p) {
        margin: 0;
      }
    }

    :global(img) {
      border-radius: 5px;
      border: 1px solid $color-accent-1;
    }
  }
</style>
